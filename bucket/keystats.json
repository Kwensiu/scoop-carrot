{
    "version": "1.43",
    "description": "Keyboard & Mouse Stats for macOS/Windows",
    "homepage": "https://github.com/debugtheworldbot/keyStats",
    "license": "MIT",
    "url": "https://github.com/debugtheworldbot/keyStats/releases/download/v1.43/KeyStats-Windows-1.43.zip",
    "hash": "4e0f5ed3fe04d12ed270391f74929470f50813b8f680009119d9d18cce8c81e0",
    "bin": "KeyStats.exe",
    "shortcuts": [
        [
            "KeyStats.exe",
            "KeyStats"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/debugtheworldbot/keyStats/releases/download/v$version/KeyStats-Windows-$version.zip"
    },
    "persist": "userdata",
    "pre_install": [
        "$appdata = \"$env:LOCALAPPDATA\\KeyStats\"",
        "if (Test-Path $appdata) {",
        "    info \"Moving existing data to persist directory...\"",
        "    Move-Item -Path $appdata -Destination \"$persist_dir\\userdata\" -Force -ErrorAction SilentlyContinue",
        "}"
    ],
    "post_install": [
        "$appdata = \"$env:LOCALAPPDATA\\KeyStats\"",
        "if (!(Test-Path $appdata)) {",
        "    info \"Creating junction for AppData...\"",
        "    New-Item -Type Junction -Path $appdata -Target \"$persist_dir\\userdata\" | Out-Null",
        "}"
    ],
    "uninstaller": {
        "script": [
            "$appdata = \"$env:LOCALAPPDATA\\KeyStats\"",
            "if (Test-Path $appdata) { Remove-Item $appdata -Recurse -Force }"
        ]
    }
}
