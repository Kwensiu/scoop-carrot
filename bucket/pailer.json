{
    "version": "1.3.0",
    "description": "A modern, powerful GUI for Scoop | 为 Scoop 打造的现代化 GUI",
    "homepage": "https://github.com/Kwensiu/Pailer",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Kwensiu/Pailer/releases/download/v1.3.0/Pailer.exe",
            "hash": "b02ed20ee99b69237860f7c04c4d5e7443e976c7c91e4ec82e16cd519a36142f"
        }
    },
    "bin": "Pailer.exe",
    "shortcuts": [
        [
            "Pailer.exe",
            "Pailer"
        ]
    ],
    "notes": [
        "Pailer is a modern GUI for Scoop package manager",
        "",
        "Data files (stored in %APPDATA%\\com.pailer.ks):",
        "  - settings.json  : Frontend settings (UI preferences, signals)",
        "  - logs/          : Application logs",
        "",
        "Cache (stored in %LOCALAPPDATA%\\com.pailer.ks):",
        "  - EBWebView/     : WebView2 cache",
        "",
        "To reset to factory settings: delete both folders above",
        "For issues: https://github.com/Kwensiu/Pailer/issues"
    ],
    "persist": "data",
    "pre_install": [
        "$roaming = \"$env:APPDATA\\com.pailer.ks\"",
        "if (Test-Path $roaming) {",
        "    info 'Migrating existing data to persist directory...'",
        "    if (!(Test-Path \"$persist_dir\\data\")) { New-Item \"$persist_dir\\data\" -ItemType Directory | Out-Null }",
        "    Move-Item -Path \"$roaming\\*\" -Destination \"$persist_dir\\data\" -Force -ErrorAction SilentlyContinue",
        "}"
    ],
    "post_install": [
        "$roaming = \"$env:APPDATA\\com.pailer.ks\"",
        "if (!(Test-Path $roaming)) {",
        "    info 'Linking AppData (Roaming) for persistence...'",
        "    New-Item -Type Junction -Path $roaming -Target \"$persist_dir\\data\" | Out-Null",
        "}"
    ],
    "uninstaller": {
        "script": [
            "$roaming = \"$env:APPDATA\\com.pailer.ks\"",
            "$local = \"$env:LOCALAPPDATA\\com.pailer.ks\"",
            "if (Test-Path $roaming) { Remove-Item $roaming -Recurse -Force -ErrorAction SilentlyContinue }",
            "if (Test-Path $local) { Remove-Item $local -Recurse -Force -ErrorAction SilentlyContinue }",
            "info 'Pailer specific registry keys were not touched for safety. You can remove them manually if needed.'"
        ]
    },
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Kwensiu/Pailer/releases/download/v$version/Pailer.exe"
            }
        }
    }
}
