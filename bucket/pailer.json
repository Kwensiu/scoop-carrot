{
    "version": "1.11.0",
    "description": "A modern, powerful GUI for Scoop",
    "homepage": "https://github.com/Kwensiu/Pailer",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Kwensiu/Pailer/releases/download/v1.11.0/Pailer.exe",
            "hash": "078e64710155370d209396636b43da9e49ec540d5237f34b6574bf6164d70913"
        }
    },
    "pre_install": [
        "$appDataPath = \"$env:APPDATA\\com.pailer.ks\"",
        "if (Test-Path $appDataPath) {",
        "    if ((Get-Item $appDataPath).Attributes -notmatch 'ReparsePoint') {",
        "        $persistPath = \"$persist_dir\\data\"",
        "        if (!(Test-Path $persistPath)) { New-Item -Path $persistPath -ItemType Directory -Force | Out-Null }",
        "        info \"Moving existing data from $appDataPath to $persistPath\"",
        "        Move-Item -Path \"$appDataPath\\*\" -Destination $persistPath -Force -ErrorAction SilentlyContinue",
        "        Remove-Item $appDataPath -Recurse -Force -ErrorAction SilentlyContinue",
        "    }",
        "}",
        "if (!(Test-Path \"$dir\\data\")) { New-Item -ItemType Directory -Path \"$dir\\data\" | Out-Null }"
    ],
    "post_install": [
        "$appDataPath = \"$env:APPDATA\\com.pailer.ks\"",
        "if (!(Test-Path $appDataPath)) {",
        "    info \"Creating junction from $appDataPath to $persist_dir\\data\"",
        "    New-Item -ItemType Junction -Path $appDataPath -Target \"$persist_dir\\data\" | Out-Null",
        "}"
    ],
    "shortcuts": [
        [
            "Pailer.exe",
            "Pailer"
        ]
    ],
    "persist": "data",
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Kwensiu/Pailer/releases/download/v$version/Pailer.exe"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
